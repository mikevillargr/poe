# Anthropic API Key (required for AI features)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Database Configuration
# Development: postgresql://user:password@localhost:5432/database_name
# Production: Use your VPS PostgreSQL connection string
DATABASE_URL=postgresql://poe_user:your_password@localhost:5432/poe_db

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3001

# Production URL (for VPS deployment)
# NEXTAUTH_URL=https://yourdomain.com

# File Uploads Directory
UPLOADS_DIR=/app/uploads

# Optional: Direct database credentials (for migrations)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=poe_db
DB_USER=poe_user
DB_PASSWORD=your_password

# Google Drive API (for exporting documents to Google Drive)
# Get credentials from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google Drive API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized JavaScript origins: http://localhost:3001
# 5. Add authorized redirect URIs: http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_API_KEY=your-api-key
